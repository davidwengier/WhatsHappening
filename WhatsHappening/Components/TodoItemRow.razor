@using Microsoft.FluentUI.AspNetCore.Components.Icons.Regular

<div class="todo-item-row" draggable="@(ShowDragHandle && !_editing ? "true" : "false")"
     @ondragstart="StartDrag" @ondragend="EndDrag"
     @ondragover="@(() => { })" @ondragover:preventDefault="ShowDragHandle"
     @ondrop="HandleDrop" @ondrop:preventDefault @ondrop:stopPropagation
     @ondragenter="DragEnter" @ondragleave="DragLeave"
     style="min-height:56px;padding:2px 4px;border-radius:4px;@DropIndicator">
    <div style="display:flex;align-items:center;width:100%;gap:8px;">
        @if (ShowDragHandle)
        {
            <div class="hide-on-mobile" style="cursor:grab;opacity:0.3;flex-shrink:0;line-height:0;padding:2px 0;">
                <svg xmlns="http://www.w3.org/2000/svg" width="10" height="16" viewBox="0 0 10 16" fill="currentColor"><circle cx="3" cy="2.5" r="1.3"/><circle cx="7" cy="2.5" r="1.3"/><circle cx="3" cy="8" r="1.3"/><circle cx="7" cy="8" r="1.3"/><circle cx="3" cy="13.5" r="1.3"/><circle cx="7" cy="13.5" r="1.3"/></svg>
            </div>
        }

        @if (_editing)
        {
            <FluentTextField @ref="_titleField" @bind-Value="_editTitle" Immediate="true"
                             @onkeypress="HandleEditKeyPress"
                             Style="flex:1;min-width:0;"
                             Appearance="FluentInputAppearance.Filled" />
        }
        else
        {
            <div style="@TitleStyle" title="@Item.Title" @onclick="TitleClick">
                @if (Item.IsGitHubLinked)
                {
                    @Item.Title
                }
                else
                {
                    @LinkHelper.Linkify(Item.Title)
                }
            </div>
        }
        @if (_editing)
        {
            <FluentButton Style="width:30px!important;height:30px!important;flex-shrink:0;"
                          OnClick="SaveEdit" Title="Save"
                          IconStart="new Size16.Checkmark()">
            </FluentButton>
            <FluentButton Style="width:30px!important;height:30px!important;flex-shrink:0;"
                          OnClick="CancelEdit" Title="Cancel"
                          IconStart="new Size16.Dismiss()">
            </FluentButton>
        }
        else if (Item.IsExternalLinked)
        {
            <FluentButton Style="width:30px!important;height:30px!important;flex-shrink:0;"
                          OnClick="@(() => ToggleExpand())"
                          IconStart="@(_expanded ? new Size16.ChevronUp() : new Size16.ChevronDown())">
            </FluentButton>
            <FluentButton OnClick="@(() => OnDelete.InvokeAsync(Item))"
                          Style="width:30px!important;height:30px!important;flex-shrink:0;"
                          IconStart="new Size16.Delete()">
            </FluentButton>
        }
        else
        {
            @if (HasNotes || HasLinks)
            {
                <FluentButton Style="width:30px!important;height:30px!important;flex-shrink:0;"
                              OnClick="@(() => ToggleExpand())"
                              IconStart="@(_expanded ? new Size16.ChevronUp() : new Size16.ChevronDown())">
                </FluentButton>
            }
            else
            {
                <FluentButton Style="width:30px!important;height:30px!important;flex-shrink:0;"
                              OnClick="StartEdit" Title="Edit"
                              IconStart="new Size16.Edit()">
                </FluentButton>
            }
            <FluentButton OnClick="@(() => OnDelete.InvokeAsync(Item))"
                          Style="width:30px!important;height:30px!important;flex-shrink:0;"
                          IconStart="new Size16.Delete()">
            </FluentButton>
        }
    </div>
    @if (Item.IsGitHubLinked)
    {
        <div style="display:flex;align-items:center;gap:4px;margin-left:48px;font-size:0.75rem;overflow:hidden;white-space:nowrap;">
            <span style="display:inline-flex;align-items:center;gap:4px;padding:2px 8px;border-radius:10px;background:var(--neutral-layer-4);white-space:nowrap;">
                <span style="line-height:0;flex-shrink:0;">@TypeIcon</span>
                <a href="@Item.GitHubUrl" target="_blank" style="color:var(--accent-fill-rest);text-decoration:none;">@Item.GitHubOwner/@Item.GitHubRepo#@Item.GitHubNumber</a>
            </span>
            @if (Item.LinkedPrNumber is not null)
            {
                <span style="display:inline-flex;align-items:center;gap:4px;padding:2px 8px;border-radius:10px;background:var(--neutral-layer-4);white-space:nowrap;">
                    <span style="line-height:0;flex-shrink:0;">@LinkedPrIcon</span>
                    <a href="@GitHubPrUrl" target="_blank" style="color:var(--accent-fill-rest);text-decoration:none;">@Item.LinkedPrRepo#@Item.LinkedPrNumber</a>
                </span>
            }
            @if (Item.Links is { Count: > 0 })
            {
                @foreach (var link in Item.Links)
                {
                    <span style="display:inline-flex;align-items:center;padding:2px 8px;border-radius:10px;background:var(--neutral-layer-4);white-space:nowrap;">
                        <a href="@link.Url" target="_blank" style="color:var(--accent-fill-rest);text-decoration:none;">@LinkDisplay(link)</a>
                    </span>
                }
            }
        </div>
    }
    else if (HasLinks)
    {
        <div style="display:flex;align-items:center;gap:4px;margin-left:48px;font-size:0.75rem;overflow:hidden;white-space:nowrap;">
            @foreach (var link in Item.Links!)
            {
                <span style="display:inline-flex;align-items:center;padding:2px 8px;border-radius:10px;background:var(--neutral-layer-4);white-space:nowrap;">
                    <a href="@link.Url" target="_blank" style="color:var(--accent-fill-rest);text-decoration:none;">@LinkDisplay(link)</a>
                </span>
            }
        </div>
    }
    @if (Item.IsGitHubLinked && _expanded)
    {
        <div style="margin-left:28px;margin-top:4px;margin-bottom:8px;padding:8px 12px;border-left:3px solid var(--accent-fill-rest);font-size:0.85rem;opacity:0.8;position:relative;max-height:180px;overflow-y:auto;">
            <FluentButton Style="position:absolute;top:4px;right:4px;width:28px!important;height:28px!important;"
                          Loading="_refreshing"
                          OnClick="Refresh"
                          Title="Refresh from GitHub"
                          IconStart="new Size16.ArrowSync()">
            </FluentButton>
            @if (Item.GitHubLabels is { Count: > 0 })
            {
                <div style="display:flex;flex-wrap:wrap;gap:4px;margin-bottom:6px;margin-right:36px;">
                    @foreach (var label in Item.GitHubLabels)
                    {
                        <span style="display:inline-block;font-size:0.7rem;padding:1px 8px;border-radius:10px;font-weight:600;background:#@(label.Color);color:@ContrastColor(label.Color);">@label.Name</span>
                    }
                </div>
            }
            @if (!string.IsNullOrEmpty(Item.GitHubBody))
            {
                <div class="markdown-body" style="margin-right:36px;">@LinkHelper.RenderMarkdown(Item.GitHubBody)</div>
            }
            else
            {
                <div style="margin-right:36px;font-style:italic;opacity:0.6;">No description. Click refresh to fetch latest.</div>
            }
        </div>
    }
    @if (!Item.IsGitHubLinked && (_expanded || _editing))
    {
        <div style="margin-left:28px;margin-top:4px;margin-bottom:8px;padding:8px 12px;border-left:3px solid var(--accent-fill-rest);font-size:0.85rem;opacity:0.8;position:relative;max-height:180px;overflow-y:auto;">
            @if (!_editing)
            {
                <FluentButton Style="position:absolute;top:4px;right:4px;width:28px!important;height:28px!important;"
                              OnClick="StartEdit" Title="Edit"
                              IconStart="new Size16.Edit()">
                </FluentButton>
                <div class="markdown-body" style="margin-right:36px;">@LinkHelper.RenderMarkdown(Item.Notes)</div>
            }
            else
            {
                <FluentTextArea @bind-Value="_editNotes" Rows="4"
                                Placeholder="Add notes..."
                                Style="width:100%;"
                                Appearance="FluentInputAppearance.Filled" />
            }
        </div>
    }
    @if (_expanded || _addingLink)
    {
        <div style="margin-left:28px;margin-top:4px;margin-bottom:8px;font-size:0.8rem;">
            @if (Item.Links is { Count: > 0 })
            {
                <div style="display:flex;flex-wrap:wrap;gap:4px;margin-bottom:4px;">
                    @foreach (var link in Item.Links)
                    {
                        <span style="display:inline-flex;align-items:center;gap:3px;padding:2px 8px;border-radius:10px;background:var(--neutral-layer-4);font-size:0.75rem;">
                            <a href="@link.Url" target="_blank" style="color:var(--accent-fill-rest);text-decoration:none;">@LinkDisplay(link)</a>
                            <span @onclick="@(() => RemoveLink(link))" style="cursor:pointer;opacity:0.5;font-size:0.65rem;" title="Remove link">✕</span>
                        </span>
                    }
                </div>
            }
            @if (_addingLink)
            {
                <div style="display:flex;align-items:center;gap:4px;">
                    <FluentTextField @ref="_linkUrlField" @bind-Value="_newLinkUrl" Immediate="true"
                                     @onkeypress="HandleLinkKeyPress"
                                     Placeholder="URL" Style="flex:2;font-size:0.8rem;"
                                     Appearance="FluentInputAppearance.Filled" />
                    <FluentTextField @bind-Value="_newLinkLabel" Immediate="true"
                                     @onkeypress="HandleLinkKeyPress"
                                     Placeholder="Label (optional)" Style="flex:1;font-size:0.8rem;"
                                     Appearance="FluentInputAppearance.Filled" />
                    <FluentButton OnClick="SaveLink" Title="Add"
                                  Style="width:28px!important;height:28px!important;"
                                  IconStart="new Size16.Checkmark()">
                    </FluentButton>
                    <FluentButton OnClick="@(() => _addingLink = false)" Title="Cancel"
                                  Style="width:28px!important;height:28px!important;"
                                  IconStart="new Size16.Dismiss()">
                    </FluentButton>
                </div>
            }
            else
            {
                <FluentButton Appearance="Appearance.Lightweight" OnClick="@(() => { _addingLink = true; _focusLinkInput = true; })"
                              IconStart="new Size16.Link()" Style="font-size:0.75rem;opacity:0.6;padding:0;">
                    Add link
                </FluentButton>
            }
        </div>
    }
</div>

@code {
    [Parameter, EditorRequired] public TodoItem Item { get; set; } = default!;

    [Parameter] public EventCallback<TodoItem> OnDelete { get; set; }
    [Parameter] public EventCallback<TodoItem> OnRefresh { get; set; }
    [Parameter] public EventCallback<TodoItem> OnSave { get; set; }
    [Parameter] public EventCallback<TodoItem> OnEditStart { get; set; }
    [Parameter] public EventCallback<TodoItem> OnEditEnd { get; set; }
    [Parameter] public bool ShowDragHandle { get; set; } = true;
    [Parameter] public bool IsGroupDragging { get; set; }
    [Parameter] public EventCallback<TodoItem> OnDragStart { get; set; }
    [Parameter] public EventCallback OnDragEnd { get; set; }
    [Parameter] public EventCallback<TodoItem> OnDropOnItem { get; set; }

    private FluentTextField? _titleField;
    private FluentTextField? _linkUrlField;
    private bool _expanded;
    private bool _editing;
    private bool _refreshing;
    private bool _focusTitleField;
    private int _dragCounter;
    private string _editTitle = string.Empty;
    private string? _editNotes;
    private bool _addingLink;
    private bool _focusLinkInput;
    private string? _newLinkUrl;
    private string? _newLinkLabel;

    private bool HasNotes => !string.IsNullOrWhiteSpace(Item.Notes);
    private bool HasLinks => Item.Links is { Count: > 0 };

    private string DropIndicator => _dragCounter > 0 && !IsGroupDragging ? "border-top:2px solid var(--accent-fill-rest);" : "";

    private void StartDrag() => OnDragStart.InvokeAsync(Item);
    private void EndDrag() => OnDragEnd.InvokeAsync();
    private void DragEnter() => _dragCounter++;
    private void DragLeave() => _dragCounter--;
    private async Task HandleDrop() { _dragCounter = 0; await OnDropOnItem.InvokeAsync(Item); }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_focusTitleField && _titleField is not null)
        {
            _focusTitleField = false;
            _titleField.FocusAsync();
        }
        if (_focusLinkInput && _linkUrlField is not null)
        {
            _focusLinkInput = false;
            _linkUrlField.FocusAsync();
        }
    }

    private async Task StartEdit()
    {
        _editTitle = Item.Title;
        _editNotes = Item.Notes;
        _editing = true;
        _expanded = false;
        _focusTitleField = true;
        await OnEditStart.InvokeAsync(Item);
    }

    private async Task HandleEditKeyPress(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            await SaveEdit();
    }

    private async Task SaveEdit()
    {
        Item.Title = _editTitle;
        Item.Notes = string.IsNullOrWhiteSpace(_editNotes) ? null : _editNotes;
        _editing = false;
        _expanded = HasNotes;
        await OnEditEnd.InvokeAsync(Item);
        await OnSave.InvokeAsync(Item);
    }

    private async Task CancelEdit()
    {
        _editing = false;
        await OnEditEnd.InvokeAsync(Item);
    }

    private bool CanExpandOrEdit => !_editing && (Item.IsExternalLinked || HasNotes || HasLinks);

    private string TitleStyle
    {
        get
        {
            var s = "flex:1;min-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;";
            if (CanExpandOrEdit) s += "cursor:pointer;";
            return s;
        }
    }

    private string StateColor => Item.GitHubState switch
    {
        "open" => "#238636",
        "closed" => "#da3633",
        "merged" => "#8957e5",
        _ => "#636c76"
    };

    private string LinkedPrColor => Item.LinkedPrState switch
    {
        "open" => "#238636",
        "closed" => "#da3633",
        "merged" => "#8957e5",
        _ => "#636c76"
    };

    private string? GitHubPrUrl => Item.LinkedPrRepo is not null && Item.LinkedPrNumber is not null
        ? $"https://github.com/{Item.LinkedPrRepo}/pull/{Item.LinkedPrNumber}"
        : null;

    private MarkupString TypeIcon=> new(Item switch
    {
        { GitHubType: "pull", GitHubState: "merged" } =>
            $"""<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16" fill="{StateColor}"><path d="M5.45 5.154A4.25 4.25 0 0 0 9.25 7.5h1.378a2.251 2.251 0 1 1 0 1.5H9.25A5.734 5.734 0 0 1 5 7.123v3.505a2.25 2.25 0 1 1-1.5 0V5.372a2.25 2.25 0 1 1 1.95-.218ZM4.25 13.5a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Zm8-8a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5ZM4.25 4a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Z"/></svg>""",
        { GitHubType: "pull" } =>
            $"""<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16" fill="{StateColor}"><path d="M1.5 3.25a2.25 2.25 0 1 1 3 2.122v5.256a2.251 2.251 0 1 1-1.5 0V5.372A2.25 2.25 0 0 1 1.5 3.25Zm5.677-.177L9.573.677A.25.25 0 0 1 10 .854V2.5h1A2.5 2.5 0 0 1 13.5 5v5.628a2.251 2.251 0 1 1-1.5 0V5a1 1 0 0 0-1-1h-1v1.646a.25.25 0 0 1-.427.177L7.177 3.427a.25.25 0 0 1 0-.354ZM3.75 2.5a.75.75 0 1 0 0 1.5.75.75 0 0 0 0-1.5Zm0 9.5a.75.75 0 1 0 0 1.5.75.75 0 0 0 0-1.5Zm8.25.75a.75.75 0 1 0 1.5 0 .75.75 0 0 0-1.5 0Z"/></svg>""",
        _ =>
            $"""<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16" fill="{StateColor}"><path d="M8 9.5a1.5 1.5 0 1 0 0-3 1.5 1.5 0 0 0 0 3Z"/><path d="M8 0a8 8 0 1 1 0 16A8 8 0 0 1 8 0ZM1.5 8a6.5 6.5 0 1 0 13 0 6.5 6.5 0 0 0-13 0Z"/></svg>"""
    });

    private MarkupString LinkedPrIcon => new(Item.LinkedPrState switch
    {
        "merged" =>
            $"""<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16" fill="{LinkedPrColor}"><path d="M5.45 5.154A4.25 4.25 0 0 0 9.25 7.5h1.378a2.251 2.251 0 1 1 0 1.5H9.25A5.734 5.734 0 0 1 5 7.123v3.505a2.25 2.25 0 1 1-1.5 0V5.372a2.25 2.25 0 1 1 1.95-.218ZM4.25 13.5a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Zm8-8a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5ZM4.25 4a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Z"/></svg>""",
        _ =>
            $"""<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16" fill="{LinkedPrColor}"><path d="M1.5 3.25a2.25 2.25 0 1 1 3 2.122v5.256a2.251 2.251 0 1 1-1.5 0V5.372A2.25 2.25 0 0 1 1.5 3.25Zm5.677-.177L9.573.677A.25.25 0 0 1 10 .854V2.5h1A2.5 2.5 0 0 1 13.5 5v5.628a2.251 2.251 0 1 1-1.5 0V5a1 1 0 0 0-1-1h-1v1.646a.25.25 0 0 1-.427.177L7.177 3.427a.25.25 0 0 1 0-.354ZM3.75 2.5a.75.75 0 1 0 0 1.5.75.75 0 0 0 0-1.5Zm0 9.5a.75.75 0 1 0 0 1.5.75.75 0 0 0 0-1.5Zm8.25.75a.75.75 0 1 0 1.5 0 .75.75 0 0 0-1.5 0Z"/></svg>"""
    });

    private void ToggleExpand() => _expanded = !_expanded;

    private void TitleClick()
    {
        if (CanExpandOrEdit)
            ToggleExpand();
    }

    // Pick black or white text based on label background luminance
    private static string ContrastColor(string hexColor)
    {
        if (hexColor.Length < 6) return "#fff";
        var r = Convert.ToInt32(hexColor[..2], 16);
        var g = Convert.ToInt32(hexColor[2..4], 16);
        var b = Convert.ToInt32(hexColor[4..6], 16);
        var luminance = (0.299 * r + 0.587 * g + 0.114 * b) / 255;
        return luminance > 0.5 ? "#000" : "#fff";
    }

    private async Task Refresh()
    {
        _refreshing = true;
        await OnRefresh.InvokeAsync(Item);
        _refreshing = false;
    }

    private async Task HandleLinkKeyPress(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await SaveLink();
    }

    private async Task SaveLink()
    {
        if (string.IsNullOrWhiteSpace(_newLinkUrl)) return;
        Item.Links ??= [];
        Item.Links.Add(new TodoLink
        {
            Url = _newLinkUrl.Trim(),
            Label = string.IsNullOrWhiteSpace(_newLinkLabel) ? null : _newLinkLabel.Trim()
        });
        _newLinkUrl = null;
        _newLinkLabel = null;
        _addingLink = false;
        await OnSave.InvokeAsync(Item);
    }

    private async Task RemoveLink(TodoLink link)
    {
        Item.Links?.Remove(link);
        await OnSave.InvokeAsync(Item);
    }

    private static string LinkDisplay(TodoLink link)
    {
        if (!string.IsNullOrWhiteSpace(link.Label)) return link.Label;
        try
        {
            var uri = new Uri(link.Url);
            var host = uri.Host.Replace("www.", "");
            var path = uri.AbsolutePath.TrimEnd('/');
            if (path.Length > 30) path = "…" + path[^25..];
            return host + path;
        }
        catch { return link.Url; }
    }
}
