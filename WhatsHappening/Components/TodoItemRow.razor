@using Microsoft.FluentUI.AspNetCore.Components.Icons.Regular

<div draggable="@(ShowDragHandle ? "true" : "false")"
     @ondragstart="StartDrag"
     @ondragover="@(() => { })" @ondragover:preventDefault="ShowDragHandle"
     @ondrop="HandleDrop" @ondrop:preventDefault
     @ondragenter="DragEnter" @ondragleave="DragLeave"
     style="@DropIndicator">
    <div style="display:flex;align-items:center;width:100%;gap:8px;">
        @if (ShowDragHandle)
        {
            <div class="hide-on-mobile" style="cursor:grab;opacity:0.3;flex-shrink:0;line-height:0;padding:2px 0;">
                <svg xmlns="http://www.w3.org/2000/svg" width="10" height="16" viewBox="0 0 10 16" fill="currentColor"><circle cx="3" cy="2.5" r="1.3"/><circle cx="7" cy="2.5" r="1.3"/><circle cx="3" cy="8" r="1.3"/><circle cx="7" cy="8" r="1.3"/><circle cx="3" cy="13.5" r="1.3"/><circle cx="7" cy="13.5" r="1.3"/></svg>
            </div>
        }
        <FluentCheckbox Value="@Item.IsComplete"
                        ValueChanged="@((bool _) => OnToggleComplete.InvokeAsync(Item))" />
        @if (Item.IsGitHubLinked)
        {
            <a href="@Item.GitHubUrl" target="_blank" title="@(Item.GitHubType == "pull" ? "Pull Request" : "Issue") #@Item.GitHubNumber" style="flex-shrink:0;line-height:0;">@TypeIcon</a>
        }
        else if (Item.IsAzDoLinked)
        {
            <a href="@Item.AzDoUrl" target="_blank" title="@Item.AzDoType #@Item.AzDoId" style="flex-shrink:0;line-height:0;">@TypeIcon</a>
        }
        <div style="@TitleStyle" title="@Item.Title" @onclick="TitleClick">
            @Item.Title
        </div>
        @if (Item.IsExternalLinked && !Item.IsComplete)
        {
            <FluentButton Style="width:30px!important;height:30px!important;flex-shrink:0;"
                          OnClick="@(() => ToggleExpand())"
                          IconStart="@(_expanded ? new Size16.ChevronUp() : new Size16.ChevronDown())">
            </FluentButton>
        }
        <FluentButton OnClick="@(() => OnDelete.InvokeAsync(Item))"
                      Style="width:30px!important;height:30px!important;flex-shrink:0;"
                      IconStart="new Size16.Delete()">
        </FluentButton>
    </div>
    @if (Item.IsGitHubLinked)
    {
        <div style="display:flex;align-items:center;gap:6px;margin-left:48px;font-size:0.75rem;opacity:@(Item.IsComplete ? "0.4" : "0.7");">
            <a href="@Item.GitHubUrl" target="_blank" style="color:var(--accent-fill-rest);text-decoration:none;">@Item.GitHubOwner/@Item.GitHubRepo#@Item.GitHubNumber</a>
            @if (Item.GitHubState is not null && !Item.IsComplete)
            {
                <span style="font-size:0.65rem;padding:1px 6px;border-radius:10px;font-weight:600;background:@StateColor;color:white;">@Item.GitHubState</span>
            }
            @if (Item.LinkedPrNumber is not null && !Item.IsComplete)
            {
                <span style="opacity:0.7;">·</span>
                <a href="@GitHubPrUrl" target="_blank" style="color:var(--accent-fill-rest);text-decoration:none;">PR: @Item.LinkedPrRepo#@Item.LinkedPrNumber</a>
                <span style="font-size:0.65rem;padding:1px 6px;border-radius:10px;font-weight:600;background:@LinkedPrColor;color:white;">@Item.LinkedPrState</span>
            }
        </div>
    }
    else if (Item.IsAzDoLinked)
    {
        <div style="display:flex;align-items:center;gap:6px;margin-left:48px;font-size:0.75rem;opacity:@(Item.IsComplete ? "0.4" : "0.7");flex-wrap:wrap;">
            <a href="@Item.AzDoUrl" target="_blank" style="color:var(--accent-fill-rest);text-decoration:none;">@Item.AzDoProject#@Item.AzDoId</a>
            @if (Item.AzDoState is not null && !Item.IsComplete)
            {
                <span style="font-size:0.65rem;padding:1px 6px;border-radius:10px;font-weight:600;background:@AzDoStateColor;color:white;">@Item.AzDoState</span>
            }
            @if (Item.AzDoAssignedTo is not null && !Item.IsComplete)
            {
                <span style="opacity:0.7;">·</span>
                <span>@Item.AzDoAssignedTo</span>
            }
            @if (Item.AzDoLinkedPrId is not null && !Item.IsComplete)
            {
                <span style="opacity:0.7;">·</span>
                <a href="@AzDoPrUrl" target="_blank" style="color:var(--accent-fill-rest);text-decoration:none;">PR: @Item.AzDoLinkedPrRepo#@Item.AzDoLinkedPrId</a>
                <span style="font-size:0.65rem;padding:1px 6px;border-radius:10px;font-weight:600;background:@AzDoPrColor;color:white;">@Item.AzDoLinkedPrState</span>
            }
        </div>
    }
    @if (Item.IsGitHubLinked && _expanded)
    {
        <div style="margin-left:28px;margin-top:4px;margin-bottom:8px;padding:8px 12px;border-left:3px solid var(--accent-fill-rest);font-size:0.85rem;opacity:0.8;position:relative;">
            <FluentButton Style="position:absolute;top:4px;right:4px;width:28px!important;height:28px!important;"
                          Loading="_refreshing"
                          OnClick="Refresh"
                          Title="Refresh from GitHub"
                          IconStart="new Size16.ArrowSync()">
            </FluentButton>
            @if (Item.GitHubLabels is { Count: > 0 })
            {
                <div style="display:flex;flex-wrap:wrap;gap:4px;margin-bottom:6px;margin-right:36px;">
                    @foreach (var label in Item.GitHubLabels)
                    {
                        <span style="display:inline-block;font-size:0.7rem;padding:1px 8px;border-radius:10px;font-weight:600;background:#@(label.Color);color:@ContrastColor(label.Color);">@label.Name</span>
                    }
                </div>
            }
            @if (!string.IsNullOrEmpty(Item.GitHubBody))
            {
                <div style="margin-right:36px;white-space:pre-wrap;word-break:break-word;line-height:1.4;">@Item.GitHubBody</div>
            }
            else
            {
                <div style="margin-right:36px;font-style:italic;opacity:0.6;">No description. Click refresh to fetch latest.</div>
            }
        </div>
    }
    else if (Item.IsAzDoLinked && _expanded)
    {
        <div style="margin-left:28px;margin-top:4px;margin-bottom:8px;padding:8px 12px;border-left:3px solid var(--accent-fill-rest);font-size:0.85rem;opacity:0.8;position:relative;">
            <FluentButton Style="position:absolute;top:4px;right:4px;width:28px!important;height:28px!important;"
                          Loading="_refreshing"
                          OnClick="Refresh"
                          Title="Refresh from Azure DevOps"
                          IconStart="new Size16.ArrowSync()">
            </FluentButton>
            @if (!string.IsNullOrEmpty(Item.AzDoBody))
            {
                <div style="margin-right:36px;white-space:pre-wrap;word-break:break-word;line-height:1.4;">@Item.AzDoBody</div>
            }
            else
            {
                <div style="margin-right:36px;font-style:italic;opacity:0.6;">No description. Click refresh to fetch latest.</div>
            }
        </div>
    }
</div>

@code {
    [Parameter, EditorRequired] public TodoItem Item { get; set; } = default!;
    [Parameter] public EventCallback<TodoItem> OnToggleComplete { get; set; }
    [Parameter] public EventCallback<TodoItem> OnDelete { get; set; }
    [Parameter] public EventCallback<TodoItem> OnRefresh { get; set; }
    [Parameter] public bool ShowDragHandle { get; set; } = true;
    [Parameter] public EventCallback<TodoItem> OnDragStart { get; set; }
    [Parameter] public EventCallback<TodoItem> OnDropOnItem { get; set; }

    private bool _expanded;
    private bool _refreshing;
    private int _dragCounter;

    private string DropIndicator => _dragCounter > 0 ? "border-top:2px solid var(--accent-fill-rest);" : "";

    private void StartDrag() => OnDragStart.InvokeAsync(Item);
    private void DragEnter() => _dragCounter++;
    private void DragLeave() => _dragCounter--;
    private async Task HandleDrop() { _dragCounter = 0; await OnDropOnItem.InvokeAsync(Item); }

    private string TitleStyle
    {
        get
        {
            var s = "flex:1;min-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;";
            if (Item.IsComplete) s += "text-decoration:line-through;opacity:0.5;";
            if (Item.IsExternalLinked && !Item.IsComplete) s += "cursor:pointer;";
            return s;
        }
    }

    private string StateColor => Item.GitHubState switch
    {
        "open" => "#238636",
        "closed" => "#da3633",
        "merged" => "#8957e5",
        _ => "#636c76"
    };

    private string LinkedPrColor => Item.LinkedPrState switch
    {
        "open" => "#238636",
        "closed" => "#da3633",
        "merged" => "#8957e5",
        _ => "#636c76"
    };

    private string AzDoStateColor => Item.AzDoState?.ToLowerInvariant() switch
    {
        "new" or "to do" => "#636c76",
        "active" or "in progress" or "doing" or "committed" => "#2f81f7",
        "resolved" or "done" => "#238636",
        "closed" => "#8957e5",
        "removed" => "#da3633",
        _ => "#636c76"
    };

    private string AzDoPrColor => Item.AzDoLinkedPrState?.ToLowerInvariant() switch
    {
        "active" => "#2f81f7",
        "completed" => "#238636",
        "abandoned" => "#da3633",
        _ => "#636c76"
    };

    private string? GitHubPrUrl => Item.LinkedPrRepo is not null && Item.LinkedPrNumber is not null
        ? $"https://github.com/{Item.LinkedPrRepo}/pull/{Item.LinkedPrNumber}"
        : null;

    private string? AzDoPrUrl => Item.AzDoOrg is not null && Item.AzDoProject is not null && Item.AzDoLinkedPrRepo is not null && Item.AzDoLinkedPrId is not null
        ? $"https://dev.azure.com/{Item.AzDoOrg}/{Item.AzDoProject}/_git/{Item.AzDoLinkedPrRepo}/pullrequest/{Item.AzDoLinkedPrId}"
        : null;

    private MarkupString TypeIcon => new(Item switch
    {
        { IsAzDoLinked: true } => Item.AzDoType?.ToLowerInvariant() switch
        {
            "bug" => """<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16" fill="#cc293d"><path d="M4.72.22a.75.75 0 0 1 1.06 0l1 1a.75.75 0 0 1-1.06 1.06l-.22-.22a3.26 3.26 0 0 0-.31 1.19h1.56a.75.75 0 0 1 0 1.5H5.12a3.28 3.28 0 0 0 .6 1.24l.78-.78a.75.75 0 1 1 1.06 1.06L6.5 6.33a3.24 3.24 0 0 0 3 0L8.44 5.27a.75.75 0 0 1 1.06-1.06l.78.78a3.28 3.28 0 0 0 .6-1.24H9.25a.75.75 0 0 1 0-1.5h1.56a3.26 3.26 0 0 0-.31-1.19l-.22.22a.75.75 0 0 1-1.06-1.06l1-1a.75.75 0 0 1 1.06 0l1 1a.75.75 0 0 1-1.06 1.06l-.14-.14c.2.4.33.85.38 1.31h.79a.75.75 0 0 1 0 1.5h-.65a4.78 4.78 0 0 1-.98 2.17l.89.89a.75.75 0 0 1-1.06 1.06l-.67-.67A4.75 4.75 0 0 1 8 8.75a4.75 4.75 0 0 1-2.39-.64l-.67.67a.75.75 0 0 1-1.06-1.06l.89-.89A4.78 4.78 0 0 1 3.79 5H3.14a.75.75 0 0 1 0-1.5h.79c.05-.46.18-.91.38-1.31l-.14.14a.75.75 0 0 1-1.06-1.06l1-1Z M2.5 10a5.5 5.5 0 1 1 11 0 5.5 5.5 0 0 1-11 0Z"/></svg>""",
            "task" => """<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16" fill="#f2cb1d"><rect x="1" y="1" width="14" height="14" rx="2"/></svg>""",
            "user story" or "product backlog item" => """<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16" fill="#009ccc"><path d="M2 3a1 1 0 0 1 1-1h10a1 1 0 0 1 1 1v10a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1V3Zm2 1v8h8V4H4Z"/></svg>""",
            "feature" => """<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16" fill="#773b93"><path d="M8 1l2.5 5H14l-4 3.5 1.5 5.5L8 12l-3.5 3 1.5-5.5L2 6h3.5Z"/></svg>""",
            "epic" => """<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16" fill="#ff7b00"><path d="M8 1l2.5 5H14l-4 3.5 1.5 5.5L8 12l-3.5 3 1.5-5.5L2 6h3.5Z"/></svg>""",
            "pull request" => $"""<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16" fill="{AzDoPrColor}"><path d="M1.5 3.25a2.25 2.25 0 1 1 3 2.122v5.256a2.251 2.251 0 1 1-1.5 0V5.372A2.25 2.25 0 0 1 1.5 3.25Zm5.677-.177L9.573.677A.25.25 0 0 1 10 .854V2.5h1A2.5 2.5 0 0 1 13.5 5v5.628a2.251 2.251 0 1 1-1.5 0V5a1 1 0 0 0-1-1h-1v1.646a.25.25 0 0 1-.427.177L7.177 3.427a.25.25 0 0 1 0-.354ZM3.75 2.5a.75.75 0 1 0 0 1.5.75.75 0 0 0 0-1.5Zm0 9.5a.75.75 0 1 0 0 1.5.75.75 0 0 0 0-1.5Zm8.25.75a.75.75 0 1 0 1.5 0 .75.75 0 0 0-1.5 0Z"/></svg>""",
            _ => """<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16" fill="#636c76"><rect x="1" y="1" width="14" height="14" rx="2"/></svg>"""
        },
        { GitHubType: "pull", GitHubState: "merged" } =>
            $"""<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16" fill="{StateColor}"><path d="M5.45 5.154A4.25 4.25 0 0 0 9.25 7.5h1.378a2.251 2.251 0 1 1 0 1.5H9.25A5.734 5.734 0 0 1 5 7.123v3.505a2.25 2.25 0 1 1-1.5 0V5.372a2.25 2.25 0 1 1 1.95-.218ZM4.25 13.5a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Zm8-8a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5ZM4.25 4a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Z"/></svg>""",
        { GitHubType: "pull" } =>
            $"""<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16" fill="{StateColor}"><path d="M1.5 3.25a2.25 2.25 0 1 1 3 2.122v5.256a2.251 2.251 0 1 1-1.5 0V5.372A2.25 2.25 0 0 1 1.5 3.25Zm5.677-.177L9.573.677A.25.25 0 0 1 10 .854V2.5h1A2.5 2.5 0 0 1 13.5 5v5.628a2.251 2.251 0 1 1-1.5 0V5a1 1 0 0 0-1-1h-1v1.646a.25.25 0 0 1-.427.177L7.177 3.427a.25.25 0 0 1 0-.354ZM3.75 2.5a.75.75 0 1 0 0 1.5.75.75 0 0 0 0-1.5Zm0 9.5a.75.75 0 1 0 0 1.5.75.75 0 0 0 0-1.5Zm8.25.75a.75.75 0 1 0 1.5 0 .75.75 0 0 0-1.5 0Z"/></svg>""",
        _ =>
            $"""<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16" fill="{StateColor}"><path d="M8 9.5a1.5 1.5 0 1 0 0-3 1.5 1.5 0 0 0 0 3Z"/><path d="M8 0a8 8 0 1 1 0 16A8 8 0 0 1 8 0ZM1.5 8a6.5 6.5 0 1 0 13 0 6.5 6.5 0 0 0-13 0Z"/></svg>"""
    });

    private void ToggleExpand() => _expanded = !_expanded;

    private void TitleClick()
    {
        if (Item.IsExternalLinked && !Item.IsComplete)
            _expanded = !_expanded;
    }

    // Pick black or white text based on label background luminance
    private static string ContrastColor(string hexColor)
    {
        if (hexColor.Length < 6) return "#fff";
        var r = Convert.ToInt32(hexColor[..2], 16);
        var g = Convert.ToInt32(hexColor[2..4], 16);
        var b = Convert.ToInt32(hexColor[4..6], 16);
        var luminance = (0.299 * r + 0.587 * g + 0.114 * b) / 255;
        return luminance > 0.5 ? "#000" : "#fff";
    }

    private async Task Refresh()
    {
        _refreshing = true;
        await OnRefresh.InvokeAsync(Item);
        _refreshing = false;
    }
}
