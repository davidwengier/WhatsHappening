@using WhatsHappening.Services
@inject AzureDevOpsService AzDo

<FluentDialog @ref="_dialog" Modal="true" TrapFocus="true" @ondialogdismiss="Cancel"
              Style="min-width:350px;max-width:500px;padding:1.5rem;">
    <h3 style="margin-top:0;">@(_isExpiry ? "Azure DevOps Token Expired" : "Sign in to Azure DevOps")</h3>
    <p style="font-size:0.85rem;opacity:0.8;">
        @if (_isExpiry)
        {
            <span>Your Azure DevOps PAT has expired or been revoked. Please create a new one.</span>
        }
        else
        {
            <span>To fetch work item details, you need a Personal Access Token (PAT).</span>
        }
    </p>
    <div style="font-size:0.82rem;opacity:0.8;margin-bottom:0.75rem;">
        <strong>Quick method</strong> — run this from the command line:
        <div style="background:var(--neutral-layer-4);padding:6px 10px;border-radius:4px;margin:0.35rem 0;font-family:monospace;font-size:0.75rem;word-break:break-all;white-space:pre-wrap;">dotnet tool run pat-generator --scopes code_write --organizations @(_org ?? "YOUR_ORG") --expires-in 30</div>
        <details style="margin-top:0.5rem;">
            <summary style="cursor:pointer;">First time? Install the tool first</summary>
            <div style="background:var(--neutral-layer-4);padding:6px 10px;border-radius:4px;margin:0.35rem 0;font-family:monospace;font-size:0.75rem;word-break:break-all;white-space:pre-wrap;">dotnet tool install --global Microsoft.DncEng.PatGeneratorTool --add-source https://pkgs.dev.azure.com/dnceng/public/_packaging/dotnet-eng/nuget/v3/index.json --prerelease</div>
        </details>
        <details style="margin-top:0.5rem;">
            <summary style="cursor:pointer;">Or create one manually</summary>
            <ol style="margin:0.25rem 0;padding-left:1.25rem;">
                <li>Go to <strong>Azure DevOps → User Settings → Personal Access Tokens</strong>
                    @if (!string.IsNullOrEmpty(_org))
                    {
                        <br /><a href="@($"https://dev.azure.com/{_org}/_usersettings/tokens")" target="_blank"
                                style="color:var(--accent-fill-rest);">dev.azure.com/@(_org)/_usersettings/tokens</a>
                    }
                </li>
                <li>Click <strong>+ New Token</strong></li>
                <li>Set scopes: <strong>Work Items → Read</strong> and <strong>Code → Read</strong></li>
                <li>Copy the generated token and paste it below</li>
            </ol>
        </details>
    </div>
    <FluentTextField @bind-Value="_patInput" Immediate="true" @onkeypress="HandleKeyPress"
                     Placeholder="Paste your PAT here"
                     Style="width:100%;margin:0.5rem 0;"
                     TextFieldType="TextFieldType.Password" />
    <div style="display:flex;justify-content:flex-end;gap:8px;margin-top:1rem;">
        <FluentButton Appearance="Appearance.Stealth" OnClick="Cancel">Cancel</FluentButton>
        <FluentButton Appearance="Appearance.Accent" OnClick="Submit" Disabled="@string.IsNullOrWhiteSpace(_patInput)">Connect</FluentButton>
    </div>
</FluentDialog>

@code {
    [Parameter] public EventCallback<string> OnPatProvided { get; set; }
    [Parameter] public EventCallback OnCancelled { get; set; }
    [Parameter] public string? Org { get; set; }
    [Parameter] public bool IsExpiry { get; set; }

    private FluentDialog? _dialog;
    private string? _patInput;
    private string? _org;
    private bool _isExpiry;

    protected override void OnParametersSet()
    {
        _org = Org;
        _isExpiry = IsExpiry;
    }

    private async Task Submit()
    {
        if (!string.IsNullOrWhiteSpace(_patInput))
        {
            await AzDo.SetPatAsync(_patInput.Trim());
            await OnPatProvided.InvokeAsync(_patInput.Trim());
            _patInput = null;
        }
    }

    private async Task Cancel()
    {
        _patInput = null;
        await OnCancelled.InvokeAsync();
    }

    private async Task HandleKeyPress(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await Submit();
    }
}
