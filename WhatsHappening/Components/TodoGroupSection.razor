@using Microsoft.FluentUI.AspNetCore.Components.Icons.Regular

@if (string.IsNullOrEmpty(Heading))
{
    <FluentCard Style="margin-bottom:0.5rem;padding:0.5rem;">
        @foreach (var todo in Items)
        {
            <TodoItemRow Item="@todo"
                         ShowDragHandle="ShowDragHandles"
                         OnDelete="OnDelete"
                         OnRefresh="OnRefresh"
                         OnSave="OnSave"
                         OnEditStart="OnEditStart"
                         OnEditEnd="OnEditEnd"
                         OnDragStart="OnDragStart"
                         OnDropOnItem="OnDropOnItem" />
        }
        @if (ShowDragHandles)
        {
            <div @ondragover="@(() => { })" @ondragover:preventDefault
                 @ondrop="HandleDropOnGroup" @ondrop:preventDefault
                 @ondragenter="@(() => _dropZoneCounter++)" @ondragleave="@(() => _dropZoneCounter--)"
                 style="min-height:12px;@(_dropZoneCounter > 0 ? "border-top:2px solid var(--accent-fill-rest);" : "")">
            </div>
        }
    </FluentCard>
}
else
{
    <FluentAccordion Style="margin-bottom:0.5rem;">
        <FluentAccordionItem Heading="@Heading" Expanded="_expanded" ExpandedChanged="HandleExpandedChanged">
            <ChildContent>
                @if (Items.Count == 0)
                {
                    <div @ondragover="@(() => { })" @ondragover:preventDefault="ShowDragHandles"
                         @ondrop="HandleDropOnGroup" @ondrop:preventDefault
                         @ondragenter="@(() => _dropZoneCounter++)" @ondragleave="@(() => _dropZoneCounter--)"
                         style="padding:8px 0;font-size:0.85rem;opacity:0.5;font-style:italic;min-height:24px;@(_dropZoneCounter > 0 ? "border-top:2px solid var(--accent-fill-rest);" : "")">
                        No items in this group
                        @if (OnDeleteGroup.HasDelegate)
                        {
                            <span> · </span><a @onclick="DeleteGroup" @onclick:preventDefault style="cursor:pointer;color:var(--accent-fill-rest);text-decoration:none;">Delete group</a>
                        }
                    </div>
                }
                else
                {
                    @foreach (var todo in Items)
                    {
                        <TodoItemRow Item="@todo"
                                     ShowDragHandle="ShowDragHandles"
                                     OnDelete="OnDelete"
                                     OnRefresh="OnRefresh"
                                     OnSave="OnSave"
                                     OnEditStart="OnEditStart"
                                     OnEditEnd="OnEditEnd"
                                     OnDragStart="OnDragStart"
                                     OnDropOnItem="OnDropOnItem" />
                    }
                    @if (ShowDragHandles)
                    {
                        <div @ondragover="@(() => { })" @ondragover:preventDefault
                             @ondrop="HandleDropOnGroup" @ondrop:preventDefault
                             @ondragenter="@(() => _dropZoneCounter++)" @ondragleave="@(() => _dropZoneCounter--)"
                             style="min-height:12px;@(_dropZoneCounter > 0 ? "border-top:2px solid var(--accent-fill-rest);" : "")">
                        </div>
                    }
                }
            </ChildContent>
        </FluentAccordionItem>
    </FluentAccordion>
}

@code {
    [Parameter] public string? Heading { get; set; }
    [Parameter] public string? GroupId { get; set; }
    [Parameter, EditorRequired] public List<TodoItem> Items { get; set; } = [];
    [Parameter] public bool StartExpanded { get; set; } = true;
    [Parameter] public bool ShowDragHandles { get; set; } = true;
    [Parameter] public EventCallback<TodoItem> OnDelete { get; set; }
    [Parameter] public EventCallback<TodoItem> OnRefresh { get; set; }
    [Parameter] public EventCallback<TodoItem> OnSave { get; set; }
    [Parameter] public EventCallback<TodoItem> OnEditStart { get; set; }
    [Parameter] public EventCallback<TodoItem> OnEditEnd { get; set; }
    [Parameter] public EventCallback OnDeleteGroup { get; set; }
    [Parameter] public EventCallback<TodoItem> OnDragStart { get; set; }
    [Parameter] public EventCallback<TodoItem> OnDropOnItem { get; set; }
    [Parameter] public EventCallback<string?> OnDropOnGroup { get; set; }
    [Parameter] public EventCallback<bool> OnExpandedChanged { get; set; }

    private bool _expanded;
    private int _dropZoneCounter;

    protected override void OnInitialized() => _expanded = StartExpanded;

    private async Task HandleExpandedChanged(bool expanded)
    {
        _expanded = expanded;
        await OnExpandedChanged.InvokeAsync(expanded);
    }

    private async Task DeleteGroup()
    {
        await OnDeleteGroup.InvokeAsync();
    }

    private async Task HandleDropOnGroup()
    {
        _dropZoneCounter = 0;
        await OnDropOnGroup.InvokeAsync(GroupId);
    }
}
