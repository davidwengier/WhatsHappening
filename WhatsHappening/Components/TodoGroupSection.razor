@using Microsoft.FluentUI.AspNetCore.Components.Icons.Regular

<FluentAccordion Style="margin-bottom:0.5rem;">
    <FluentAccordionItem Heading="@Heading" Expanded="_expanded">
        <HeadingTemplate>
            <div style="display:flex;align-items:center;gap:6px;width:100%;">
                <span style="font-weight:600;font-size:0.95rem;flex:1;">@Heading</span>
                @if (OnDeleteGroup.HasDelegate)
                {
                    <span @onclick="DeleteGroup" @onclick:stopPropagation="true">
                        <FluentButton Style="width:26px!important;height:26px!important;flex-shrink:0;"
                                      Title="Delete group"
                                      IconStart="new Size16.Delete()">
                        </FluentButton>
                    </span>
                }
            </div>
        </HeadingTemplate>
        <ChildContent>
            @if (Items.Count == 0)
            {
                <div style="padding:8px 0;font-size:0.85rem;opacity:0.5;font-style:italic;">No items in this group</div>
            }
            else
            {
                @foreach (var todo in Items)
                {
                    <TodoItemRow Item="@todo"
                                 OnToggleComplete="OnToggleComplete"
                                 OnDelete="OnDelete"
                                 OnRefresh="OnRefresh" />
                }
            }
        </ChildContent>
    </FluentAccordionItem>
</FluentAccordion>

@code {
    [Parameter, EditorRequired] public string Heading { get; set; } = string.Empty;
    [Parameter, EditorRequired] public List<TodoItem> Items { get; set; } = [];
    [Parameter] public bool StartExpanded { get; set; } = true;
    [Parameter] public EventCallback<TodoItem> OnToggleComplete { get; set; }
    [Parameter] public EventCallback<TodoItem> OnDelete { get; set; }
    [Parameter] public EventCallback<TodoItem> OnRefresh { get; set; }
    [Parameter] public EventCallback OnDeleteGroup { get; set; }

    private bool _expanded;

    protected override void OnInitialized() => _expanded = StartExpanded;

    private async Task DeleteGroup()
    {
        await OnDeleteGroup.InvokeAsync();
    }
}
