@page "/"
@using Microsoft.FluentUI.AspNetCore.Components.Icons.Regular
@using Microsoft.AspNetCore.Components.Web
@using WhatsHappening.Services
@inject FirestoreService Firestore
@inject GitHubService GitHub
@attribute [Authorize]

<PageTitle>What's Happening</PageTitle>

@if (_refreshTotal > 0)
{
    <FluentProgress Min="0" Max="@_refreshTotal" Value="@_refreshDone"
                    Style="height:2px;--progress-min-height:2px;" />
}

<div class="floating-input">
    <div class="input-row">
        <FluentTextField @bind-Value="_newTodoItem"
                         Immediate="true"
                         @onkeypress="HandleKeyPress"
                         Placeholder="@InputPlaceholder"
                         Class="borderless-textfield"
                         Appearance="FluentInputAppearance.Filled" />
        @if (_groups.Count > 0)
        {
            <GroupPicker Groups="_groups" SelectedGroupId="@_selectedGroupId"
                         OnSelectedGroupChanged="@(id => _selectedGroupId = id)" />
        }
        <FluentButton @onclick="AddTodo" Title="Add todo" AriaLabel="Add todo"
                      Style="width:30px!important;height:30px!important;flex-shrink:0;"
                      IconStart="new Size16.Add()">
        </FluentButton>
    </div>
</div>

<div class="centered-list-container">
    @if (_loading)
    {
        <div class="list-content">
            <FluentProgress />
        </div>
    }
    else if (_firestoreError is not null)
    {
        <div class="list-content">
            <div style="text-align: center; padding: 2rem; color: var(--neutral-foreground-hint);">
                <FluentIcon Value="new Size24.CloudDismiss()" Color="Color.Neutral" />
                <h3>Firestore is not available</h3>
                <p>To save your todos, you need to enable Cloud Firestore in your Firebase project.</p>
                <p><FluentAnchor Href="setup-help" Appearance="Appearance.Accent">View setup guide</FluentAnchor></p>
                <p style="font-size: 0.85rem; opacity: 0.7;">@_firestoreError</p>
            </div>
        </div>
    }
    else
    {
        @if (AllActiveCount == 0)
        {
            <div class="list-content">
                <div style="text-align: center; padding: 2rem; color: var(--neutral-foreground-hint);">
                    <p>No todos yet. Type something above to get started!</p>
                </div>
            </div>
        }
        else
        {
            <div class="groups-grid">
                @* Ungrouped active items *@
                @if (UngroupedActive.Count > 0)
                {
                    <TodoGroupSection Items="UngroupedActive"
                                      OnToggleComplete="ToggleComplete"
                                      OnDelete="RemoveTodo"
                                      OnRefresh="RefreshGitHub"
                                      OnSave="SaveTodo"
                                      OnDragStart="HandleDragStart"
                                      OnDropOnItem="HandleDropOnItem"
                                      OnDropOnGroup="HandleDropOnGroup" />
                }

                @* User-created groups *@
                @foreach (var group in _groups.OrderBy(g => g.Order))
                {
                    var items = ActiveItemsForGroup(group.Id!);
                    <TodoGroupSection Heading="@($"{group.Name} ({items.Count})")"
                                      GroupId="@group.Id"
                                      Items="items"
                                      OnToggleComplete="ToggleComplete"
                                      OnDelete="RemoveTodo"
                                      OnRefresh="RefreshGitHub"
                                      OnSave="SaveTodo"
                                      OnDeleteGroup="@(() => DeleteGroup(group))"
                                      OnDragStart="HandleDragStart"
                                      OnDropOnItem="HandleDropOnItem"
                                      OnDropOnGroup="HandleDropOnGroup" />
                }
            </div>
        }

        <div class="list-content">
            <AddGroupInput OnAddGroup="AddGroup" />

            @* Completed items (built-in group) *@
            @if (CompletedItems.Count > 0)
            {
                <TodoGroupSection Heading="@($"Completed ({CompletedItems.Count})")"
                                  Items="CompletedItems"
                                  StartExpanded="false"
                                  ShowDragHandles="false"
                                  OnToggleComplete="ToggleComplete"
                                  OnDelete="RemoveTodo"
                                  OnRefresh="RefreshGitHub"
                                  OnSave="SaveTodo" />
            }
        </div>
    }
</div>

@code
{
    private string? _newTodoItem;
    private string _selectedGroupId = "";
    private List<TodoItem> _todoList = [];
    private List<TodoGroup> _groups = [];
    private bool _loading = true;
    private string? _firestoreError;
    private string InputPlaceholder => _selectedGroupId == "" ? "Enter a Todo" : $"Add to {SelectedGroupName}";

    private string SelectedGroupName => _selectedGroupId == "" ? "Ungrouped" : _groups.FirstOrDefault(g => g.Id == _selectedGroupId)?.Name ?? "group";

    private TodoItem? _draggedItem;
    private int _refreshTotal;
    private int _refreshDone;
    private List<TodoItem> UngroupedActive=> _todoList
        .Where(t => !t.IsComplete && string.IsNullOrEmpty(t.GroupId))
        .OrderBy(t => t.Order).ToList();

    private List<TodoItem> ActiveItemsForGroup(string groupId) => _todoList
        .Where(t => !t.IsComplete && t.GroupId == groupId)
        .OrderBy(t => t.Order).ToList();

    private List<TodoItem> CompletedItems => _todoList
        .Where(t => t.IsComplete)
        .OrderByDescending(t => t.CompletedAt ?? 0).ToList();

    private int AllActiveCount => _todoList.Count(t => !t.IsComplete);

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var todosTask = Firestore.GetTodosAsync();
            var groupsTask = Firestore.GetGroupsAsync();
            _todoList = await todosTask;
            _groups = await groupsTask;
        }
        catch (Exception ex)
        {
            _firestoreError = ex.Message;
        }
        finally
        {
            _loading = false;
        }

        if (_firestoreError is null)
            _ = RefreshAllGitHubStatuses();
    }

    private async Task RefreshAllGitHubStatuses()
    {
        var externalItems = _todoList.Where(t => t.IsGitHubLinked && !t.IsComplete).ToList();
        if (externalItems.Count == 0) return;

        _refreshTotal = externalItems.Count;
        _refreshDone = 0;
        StateHasChanged();

        foreach (var item in externalItems)
        {
            try { await RefreshGitHub(item); }
            catch { }
            _refreshDone++;
            StateHasChanged();
        }

        // Brief pause so user sees 100%, then hide
        await Task.Delay(500);
        _refreshTotal = 0;
        _refreshDone = 0;
        StateHasChanged();
    }

    private async Task AddTodo()
    {
        if (!string.IsNullOrWhiteSpace(_newTodoItem))
        {
            var todo = new TodoItem(_newTodoItem) { Order = _todoList.Count };
            if (!string.IsNullOrEmpty(_selectedGroupId))
                todo.GroupId = _selectedGroupId;

            if (GitHubService.TryParseGitHubUrl(_newTodoItem, out var owner, out var repo, out var number, out var type))
            {
                todo.GitHubUrl = _newTodoItem.Trim();
                todo.GitHubOwner = owner;
                todo.GitHubRepo = repo;
                todo.GitHubNumber = number;
                todo.GitHubType = type;

                var details = await GitHub.FetchIssuePrDetailsAsync(owner, repo, number, type);
                if (details is not null)
                {
                    todo.Title = details.Value.Title;
                    todo.GitHubState = details.Value.State;
                    todo.GitHubBody = details.Value.Body;
                    todo.GitHubLabels = details.Value.Labels;
                }
                else
                {
                    todo.Title = $"{owner}/{repo}#{number}";
                }

                if (type == "issue")
                {
                    var pr = await GitHub.FetchLinkedPrAsync(owner, repo, number);
                    todo.LinkedPrNumber = pr?.Number;
                    todo.LinkedPrRepo = pr?.Repo;
                    todo.LinkedPrState = pr?.State;
                }
            }

            try
            {
                todo.Id = await Firestore.AddTodoAsync(todo);
                _todoList.Add(todo);
                _newTodoItem = string.Empty;
                _firestoreError = null;
            }
            catch (Exception ex)
            {
                _firestoreError = ex.Message;
            }
        }
    }

    private async Task AddGroup(string name)
    {
        var group = new TodoGroup(name) { Order = _groups.Count };
        try
        {
            group.Id = await Firestore.AddGroupAsync(group);
            _groups.Add(group);
            _firestoreError = null;
        }
        catch (Exception ex)
        {
            _firestoreError = ex.Message;
        }
    }

    private async Task DeleteGroup(TodoGroup group)
    {
        if (group.Id is null) return;
        try
        {
            // Move items in this group to ungrouped
            foreach (var todo in _todoList.Where(t => t.GroupId == group.Id))
            {
                todo.GroupId = null;
                if (todo.Id is not null)
                    await Firestore.UpdateTodoAsync(todo.Id, new { groupId = (string?)null });
            }
            await Firestore.DeleteGroupAsync(group.Id);
            _groups.Remove(group);
            _firestoreError = null;
        }
        catch (Exception ex)
        {
            _firestoreError = ex.Message;
        }
    }

    private async Task RefreshGitHub(TodoItem todo)
    {
        if (!todo.IsGitHubLinked || todo.GitHubOwner is null || todo.GitHubNumber is null) return;
        var details = await GitHub.FetchIssuePrDetailsAsync(
            todo.GitHubOwner, todo.GitHubRepo!, todo.GitHubNumber.Value, todo.GitHubType ?? "issue");
        if (details is not null)
        {
            todo.Title = details.Value.Title;
            todo.GitHubState = details.Value.State;
            todo.GitHubBody = details.Value.Body;
            todo.GitHubLabels = details.Value.Labels;

            // Fetch linked PR for issues
            if (todo.GitHubType == "issue")
            {
                var pr = await GitHub.FetchLinkedPrAsync(todo.GitHubOwner, todo.GitHubRepo!, todo.GitHubNumber.Value);
                todo.LinkedPrNumber = pr?.Number;
                todo.LinkedPrRepo = pr?.Repo;
                todo.LinkedPrState = pr?.State;
            }

            if (todo.Id is not null)
                await Firestore.UpdateTodoAsync(todo.Id, new
                {
                    title = todo.Title,
                    gitHubState = todo.GitHubState,
                    gitHubBody = todo.GitHubBody,
                    gitHubLabels = todo.GitHubLabels?.Select(l => new { name = l.Name, color = l.Color }).ToArray(),
                    linkedPrNumber = todo.LinkedPrNumber,
                    linkedPrRepo = todo.LinkedPrRepo,
                    linkedPrState = todo.LinkedPrState
                });
        }
    }

    private void HandleDragStart(TodoItem item) => _draggedItem = item;

    private async Task HandleDropOnItem(TodoItem target)
    {
        if (_draggedItem is null || _draggedItem == target) { _draggedItem = null; return; }

        var targetGroupId = target.GroupId ?? "";
        _draggedItem.GroupId = string.IsNullOrEmpty(targetGroupId) ? null : target.GroupId;

        var groupItems = _todoList
            .Where(t => !t.IsComplete && (t.GroupId ?? "") == targetGroupId && t != _draggedItem)
            .OrderBy(t => t.Order)
            .ToList();

        var targetIndex = groupItems.IndexOf(target);
        groupItems.Insert(targetIndex, _draggedItem);

        for (int i = 0; i < groupItems.Count; i++)
        {
            if (groupItems[i].Order != i || groupItems[i] == _draggedItem)
            {
                groupItems[i].Order = i;
                if (groupItems[i].Id is not null)
                    await Firestore.UpdateTodoAsync(groupItems[i].Id!, new { order = i, groupId = groupItems[i].GroupId });
            }
        }

        _draggedItem = null;
    }

    private async Task HandleDropOnGroup(string? groupId)
    {
        if (_draggedItem is null) return;

        _draggedItem.GroupId = string.IsNullOrEmpty(groupId) ? null : groupId;

        var groupItems = _todoList
            .Where(t => !t.IsComplete && (t.GroupId ?? "") == (groupId ?? "") && t != _draggedItem)
            .ToList();

        _draggedItem.Order = groupItems.Count > 0 ? groupItems.Max(t => t.Order) + 1 : 0;

        if (_draggedItem.Id is not null)
            await Firestore.UpdateTodoAsync(_draggedItem.Id, new { order = _draggedItem.Order, groupId = _draggedItem.GroupId });

        _draggedItem = null;
    }

    private async Task ToggleComplete(TodoItem todo)
    {
        if (todo.Id is null) return;
        todo.IsComplete = !todo.IsComplete;
        todo.CompletedAt = todo.IsComplete ? DateTimeOffset.UtcNow.ToUnixTimeMilliseconds() : null;
        try
        {
            await Firestore.UpdateTodoAsync(todo.Id, new { isComplete = todo.IsComplete, completedAt = todo.CompletedAt });
            _firestoreError = null;
        }
        catch (Exception ex)
        {
            todo.IsComplete = !todo.IsComplete;
            todo.CompletedAt = todo.IsComplete ? todo.CompletedAt : null;
            _firestoreError = ex.Message;
        }
    }

    private async Task SaveTodo(TodoItem todo)
    {
        if (todo.Id is null) return;
        try
        {
            await Firestore.UpdateTodoAsync(todo.Id, new { title = todo.Title, notes = todo.Notes });
            _firestoreError = null;
        }
        catch (Exception ex)
        {
            _firestoreError = ex.Message;
        }
    }

    private async Task RemoveTodo(TodoItem todo)
    {
        if (todo.Id is not null)
        {
            try
            {
                await Firestore.DeleteTodoAsync(todo.Id);
                _todoList.Remove(todo);
                _firestoreError = null;
            }
            catch (Exception ex)
            {
                _firestoreError = ex.Message;
            }
        }
    }

    private async Task HandleKeyPress(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await AddTodo();
    }

}