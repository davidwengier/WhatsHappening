@page "/setup"
@using System.Text
@using System.Text.Json
@inject FirebaseAuthService AuthService
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime

<PageTitle>Setup - What's Happening</PageTitle>

<div style="display: flex; justify-content: center; align-items: center; min-height: 60vh;">
    <FluentCard Style="max-width: 500px; padding: 2rem;">
        <h2>Welcome to What's Happening</h2>
        <p>
            Enter your Firebase project configuration to get started.
            Find these values in the
            <a href="https://console.firebase.google.com" target="_blank">Firebase Console</a>
            under Project Settings.
            Need help? Follow the <a href="setup-help">step-by-step guide</a>.
        </p>

        <FluentTextField @bind-Value="_apiKey"
                         Label="API Key"
                         Style="width: 100%; margin-bottom: 1rem;" />

        <FluentTextField @bind-Value="_authDomain"
                         Label="Auth Domain"
                         Placeholder="your-project.firebaseapp.com"
                         Style="width: 100%; margin-bottom: 1rem;" />

        <FluentTextField @bind-Value="_projectId"
                         Label="Project ID"
                         Style="width: 100%; margin-bottom: 1rem;" />

        @if (!string.IsNullOrEmpty(_error))
        {
            <FluentMessageBar Title="Error" Intent="MessageIntent.Error" Style="margin-bottom: 1rem;">
                @_error
            </FluentMessageBar>
        }

        @if (_showAppliedMessage)
        {
            <FluentMessageBar Title="Config applied" Intent="MessageIntent.Success" Style="margin-bottom: 1rem;">
                Configuration loaded from link. Review the values above and click Save &amp; Continue.
            </FluentMessageBar>
        }

        <FluentButton Appearance="Appearance.Accent" OnClick="SaveConfig" Disabled="_saving">
            @(_saving ? "Saving..." : "Save & Continue")
        </FluentButton>

        @if (HasAllFields)
        {
            <div style="margin-top: 1.5rem; padding-top: 1rem; border-top: 1px solid var(--neutral-stroke-rest);">
                <h4>Setup on another device</h4>
                <p style="font-size: 0.85rem; margin-bottom: 0.5rem;">
                    Copy this link to set up another browser or device with the same config.
                    The link expires in 7 days.
                </p>
                <FluentMessageBar Title="Keep it private" Intent="MessageIntent.Warning" Style="margin-bottom: 0.75rem; font-size: 0.85rem;">
                    Only send this to yourself &mdash; don't share it publicly.
                </FluentMessageBar>
                <FluentTextField Value="@ShareLink" ReadOnly="true" Style="width: 100%; margin-bottom: 0.5rem;" />
                <FluentButton Appearance="Appearance.Outline" OnClick="CopyLink" IconStart="@(new Icons.Regular.Size16.Copy())">
                    @(_copied ? "Copied!" : "Copy link")
                </FluentButton>
            </div>
        }
    </FluentCard>
</div>

@code {
    [SupplyParameterFromQuery(Name = "c")]
    public string? QsConfig { get; set; }

    private string _apiKey = "";
    private string _authDomain = "";
    private string _projectId = "";
    private string? _error;
    private bool _saving;
    private bool _copied;
    private bool _showAppliedMessage;

    private bool HasAllFields =>
        !string.IsNullOrWhiteSpace(_apiKey) &&
        !string.IsNullOrWhiteSpace(_authDomain) &&
        !string.IsNullOrWhiteSpace(_projectId);

    private string ShareLink
    {
        get
        {
            var baseUri = Navigation.BaseUri.TrimEnd('/');
            var encoded = EncodeConfig(new FirebaseConfig
            {
                ApiKey = _apiKey.Trim(),
                AuthDomain = _authDomain.Trim(),
                ProjectId = _projectId.Trim(),
            });
            return $"{baseUri}/setup?c={Uri.EscapeDataString(encoded)}";
        }
    }

    protected override async Task OnInitializedAsync()
    {
        // Load existing config if revisiting setup
        var existing = await AuthService.GetConfigAsync();
        if (existing is not null)
        {
            _apiKey = existing.ApiKey;
            _authDomain = existing.AuthDomain;
            _projectId = existing.ProjectId;
        }

        // Pre-fill from share link
        if (!string.IsNullOrWhiteSpace(QsConfig))
        {
            var decoded = DecodeConfig(QsConfig);
            if (decoded is not null)
            {
                _apiKey = decoded.ApiKey;
                _authDomain = decoded.AuthDomain;
                _projectId = decoded.ProjectId;
                _showAppliedMessage = true;
            }
            else
            {
                _error = "This setup link is invalid or has expired.";
            }
        }
    }

    private async Task SaveConfig()
    {
        _error = null;

        if (!HasAllFields)
        {
            _error = "All fields are required.";
            return;
        }

        _saving = true;
        try
        {
            await AuthService.SetConfigAsync(new FirebaseConfig
            {
                ApiKey = _apiKey.Trim(),
                AuthDomain = _authDomain.Trim(),
                ProjectId = _projectId.Trim(),
            });

            // Force full reload so Firebase initializes with the new config
            Navigation.NavigateTo("", forceLoad: true);
        }
        catch (Exception ex)
        {
            _error = $"Failed to save configuration: {ex.Message}";
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task CopyLink()
    {
        await JSRuntime.InvokeVoidAsync("navigator.clipboard.writeText", ShareLink);
        _copied = true;
        _ = ResetCopiedAsync();
    }

    private async Task ResetCopiedAsync()
    {
        await Task.Delay(2000);
        _copied = false;
        StateHasChanged();
    }

    // XOR-based obfuscation keyed on the creation date (not truly secure, just opaque)
    private static string EncodeConfig(FirebaseConfig config)
    {
        var created = DateTime.UtcNow.ToString("yyyy-MM-dd");
        var expires = DateTime.UtcNow.AddDays(7).ToString("yyyy-MM-dd");
        var payload = JsonSerializer.Serialize(new
        {
            a = config.ApiKey,
            d = config.AuthDomain,
            p = config.ProjectId,
            e = expires,
        });

        var bytes = Encoding.UTF8.GetBytes(payload);
        var key = Encoding.UTF8.GetBytes(created);
        for (int i = 0; i < bytes.Length; i++)
            bytes[i] ^= key[i % key.Length];

        return Convert.ToBase64String(bytes)
            .TrimEnd('=')
            .Replace('+', '-')
            .Replace('/', '_');
    }

    private static FirebaseConfig? DecodeConfig(string encoded)
    {
        // Try each of the last 8 days as the XOR key (handles timezone edge cases)
        for (int d = 0; d <= 7; d++)
        {
            try
            {
                var key = Encoding.UTF8.GetBytes(
                    DateTime.UtcNow.AddDays(-d).ToString("yyyy-MM-dd"));

                var padded = encoded.Replace('-', '+').Replace('_', '/');
                switch (padded.Length % 4)
                {
                    case 2: padded += "=="; break;
                    case 3: padded += "="; break;
                }

                var bytes = Convert.FromBase64String(padded);
                for (int i = 0; i < bytes.Length; i++)
                    bytes[i] ^= key[i % key.Length];

                var json = Encoding.UTF8.GetString(bytes);
                using var doc = JsonDocument.Parse(json);
                var root = doc.RootElement;

                var expiry = DateTime.Parse(root.GetProperty("e").GetString()!);
                if (expiry < DateTime.UtcNow.Date)
                    return null;

                return new FirebaseConfig
                {
                    ApiKey = root.GetProperty("a").GetString()!,
                    AuthDomain = root.GetProperty("d").GetString()!,
                    ProjectId = root.GetProperty("p").GetString()!,
                };
            }
            catch
            {
                continue;
            }
        }

        return null;
    }
}
