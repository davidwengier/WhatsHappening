@inherits LayoutComponentBase
@inject FirebaseAuthService AuthService
@inject NavigationManager Navigation

<FluentLayout>
    <FluentHeader>
        <a href="" style="color: inherit; text-decoration: none; font-weight: bold;">What's Happening</a>
        <FluentSpacer />
        <AuthorizeView>
            <Authorized>
                <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center">
                    @if (context.User.FindFirst("picture")?.Value is string photoUrl)
                    {
                        <FluentPersona Name="@context.User.Identity?.Name"
                                       ImageSize="24px"
                                       Image="@photoUrl"
                                       Style="color: var(--neutral-foreground-rest);" />
                    }
                    else
                    {
                        <span style="font-size: 0.85rem;">@context.User.Identity?.Name</span>
                    }
                    <FluentButton Appearance="Appearance.Stealth"
                                  OnClick="@(() => Navigation.NavigateTo("setup"))"
                                  Title="Settings"
                                  IconStart="@(new Icons.Regular.Size20.Settings())"
                                  Style="color: var(--neutral-foreground-rest);" />
                    <FluentButton Appearance="Appearance.Stealth"
                                  OnClick="SignOut"
                                  Title="Sign out"
                                  IconStart="@(new Icons.Regular.Size20.SignOut())"
                                  Style="color: var(--neutral-foreground-rest);" />
                </FluentStack>
            </Authorized>
        </AuthorizeView>
    </FluentHeader>
    <UpdateChecker />
    <FluentBodyContent Class="body-content">
        <ErrorBoundary>
            <ChildContent>
                <div class="content">
                    @Body
                </div>
            </ChildContent>
            <ErrorContent Context="ex">
                <div class="blazor-error-boundary">@ex.Message</div>
            </ErrorContent>
        </ErrorBoundary>
    </FluentBodyContent>
</FluentLayout>

@code {
    private async Task SignOut()
    {
        await AuthService.SignOutAsync();
        Navigation.NavigateTo("login");
    }
}