@inherits LayoutComponentBase
@inject FirebaseAuthService AuthService
@inject NavigationManager Navigation

<style>
    @@media (max-width: 600px) {
        .hide-on-mobile { display: none !important; }
        .persona-mobile ::deep .persona-name { display: none !important; }
    }
</style>

<FluentLayout>
    <FluentHeader>
        <div style="display:flex;align-items:center;justify-content:space-between;width:100%;">
            <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" Style="gap:8px;">
                <a href="" style="color: inherit; text-decoration: none; font-weight: bold; white-space: nowrap; font-size: 1.1rem;">What's Happening</a>
                <span class="hide-on-mobile">
                    <UpdateChecker />
                </span>
            </FluentStack>
            <AuthorizeView>
                <Authorized>
                    <div style="display:flex;align-items:center;gap:8px;margin-left:auto;flex-shrink:0;">
                        @if (context.User.FindFirst("picture")?.Value is string photoUrl)
                        {
                            <img src="@photoUrl" alt="@context.User.Identity?.Name" title="@context.User.Identity?.Name"
                                 style="width:24px;height:24px;border-radius:50%;" />
                        }
                        <span class="hide-on-mobile" style="font-size:0.85rem;white-space:nowrap;color:white;font-weight:normal;">@context.User.Identity?.Name</span>
                        <FluentButton Appearance="Appearance.Stealth"
                                      OnClick="@(() => Navigation.NavigateTo("setup"))"
                                      Title="Settings"
                                      IconStart="@(new Icons.Regular.Size20.Settings())"
                                      Style="color: var(--neutral-foreground-rest);" />
                        <FluentButton Appearance="Appearance.Stealth"
                                      OnClick="SignOut"
                                      Title="Sign out"
                                      IconStart="@(new Icons.Regular.Size20.SignOut())"
                                      Style="color: var(--neutral-foreground-rest);" />
                    </div>
                </Authorized>
            </AuthorizeView>
        </div>
    </FluentHeader>
    <FluentBodyContent Class="body-content">
        <ErrorBoundary>
            <ChildContent>
                <div class="content">
                    @Body
                </div>
            </ChildContent>
            <ErrorContent Context="ex">
                <div class="blazor-error-boundary">@ex.Message</div>
            </ErrorContent>
        </ErrorBoundary>
    </FluentBodyContent>
</FluentLayout>

@code {
    private async Task SignOut()
    {
        await AuthService.SignOutAsync();
        Navigation.NavigateTo("login");
    }
}